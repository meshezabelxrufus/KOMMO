# =============================================================================
# Kommo CRM Integration — Environment Configuration Template
# =============================================================================
#
# SETUP INSTRUCTIONS
# ──────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values below
# 3. NEVER commit .env to git (already in .gitignore)
# 4. Run ./setup.sh to auto-generate TOKEN_ENCRYPTION_KEY
#
# SECURITY RULES
# ──────────────
# ✗ NEVER hardcode secrets in Python source files
# ✗ NEVER log or print KOMMO_CLIENT_SECRET or TOKEN_ENCRYPTION_KEY
# ✗ NEVER commit .env — use environment variables in CI/CD instead
# ✗ NEVER share .env files via Slack, email, or any chat tool
# ✓ Use a secrets manager (AWS Secrets Manager, Vault) in production
# ✓ Rotate KOMMO_CLIENT_SECRET periodically
# ✓ Use different credentials per environment (dev/staging/prod)
# =============================================================================


# =============================================================================
# KOMMO OAUTH 2.0 CREDENTIALS  ← REQUIRED
# Obtain from: https://www.kommo.com/developers/ → My Apps
# =============================================================================

# Your OAuth App Client ID (public, non-secret)
KOMMO_CLIENT_ID=your_client_id_here

# Your OAuth App Client Secret — TREAT LIKE A PASSWORD
KOMMO_CLIENT_SECRET=your_client_secret_here

# OAuth Redirect URI — must EXACTLY match the URI in your Kommo App settings
# For local development: http://localhost:8000/callback
# For production: use HTTPS (e.g. https://yourdomain.com/kommo/callback)
KOMMO_REDIRECT_URI=http://localhost:8000/callback

# Your Kommo account subdomain (the part before .kommo.com)
# Example: if your Kommo URL is mycompany.kommo.com → set KOMMO_SUBDOMAIN=mycompany
# Do NOT include https:// or .kommo.com
KOMMO_SUBDOMAIN=yoursubdomain


# =============================================================================
# TOKEN STORAGE ENCRYPTION  ← REQUIRED
# =============================================================================

# Fernet symmetric encryption key for the stored OAuth tokens.
# Auto-generated by setup.sh. To generate manually:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# RULES:
#   - Must be exactly 44 base64url characters (generated by Fernet.generate_key())
#   - Use a DIFFERENT key for each environment (dev/staging/prod)
#   - Back this up securely — losing it means re-authorizing OAuth
#   - Rotating it requires re-encrypting the token store
TOKEN_ENCRYPTION_KEY=your_fernet_key_here

# Path to the encrypted OAuth token store (relative to project root)
TOKEN_STORE_PATH=auth/token_store.json

# Path to the incremental sync state file (relative to project root)
SYNC_STATE_PATH=state/sync_state.json


# =============================================================================
# API BEHAVIOUR  ← OPTIONAL (safe defaults shown)
# =============================================================================

# Records per API page (1–250). 250 = minimum API calls.
KOMMO_MAX_PAGE_SIZE=250

# Client-side rate limit (requests/second). Kommo's limit is 7 req/s.
# Lower this if you share the quota with other integrations.
KOMMO_RATE_LIMIT_PER_SECOND=7

# TCP connection timeout in seconds (how long to wait for the server to accept)
KOMMO_CONNECT_TIMEOUT=10

# Response read timeout in seconds (how long to wait for response body)
KOMMO_READ_TIMEOUT=30

# Maximum retry attempts for transient failures (0 = no retries)
KOMMO_MAX_RETRIES=3


# =============================================================================
# OUTPUT  ← OPTIONAL (safe defaults shown)
# =============================================================================

# Root directory for all extracted JSON files
OUTPUT_DIR=outputs


# =============================================================================
# LOGGING  ← OPTIONAL (safe defaults shown)
# =============================================================================

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Use DEBUG only in development (verbose HTTP traffic)
LOG_LEVEL=INFO

# Directory for rotating log files
LOG_DIR=logs

# Write logs to rotating files (true/false)
LOG_TO_FILE=true

# Max size per log file before rotation (bytes). Default: 10485760 = 10 MB
LOG_MAX_BYTES=10485760

# Number of rotated backup files to keep per log file
LOG_BACKUP_COUNT=5
