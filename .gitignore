# =============================================================================
# Kommo Integration — .gitignore
# =============================================================================

# Environment & Secrets — NEVER commit these
.env
auth/token_store.json
state/tokens.enc
state/*.enc
state/sync_state.json
state/*.json
*.key

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# Virtual Environments
.venv/
venv/
env/
ENV/

# Testing & Coverage
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Output data — committed for client demo
# outputs/*.json
outputs/data/*.json
outputs/errors/*.json

# Logs — committed for client demo
# logs/*.log
# logs/*.log.*
# logs/analytics_*.json

# Daily AI exports — generated data, not source code
daily_exports/*.json

# n8n exported workflow JSONs — these are deploy artifacts, not source
# (the Python deploy scripts ARE committed; these are the generated outputs)
kommo_*.json

# Google credentials / service account JSON files — NEVER commit
*.apps.googleusercontent.com.json
*-bdf40efd77e5.json
service_account*.json
credentials*.json
