# =============================================================================
# Kommo CRM Platform — Production Environment Variables
# =============================================================================
# Copy to /opt/kommo-platform/secrets/.env on the server and fill in values.
# chmod 600 /opt/kommo-platform/secrets/.env
# NEVER commit this file to git.
# =============================================================================


# ── Server / Domains ─────────────────────────────────────────────────────────
# n8n workflow editor and webhooks
# Example: n8n.yourdomain.com
N8N_DOMAIN=n8n.yourdomain.com

# Python pipeline health/trigger API
# Example: api.yourdomain.com
API_DOMAIN=api.yourdomain.com

# Email for Let's Encrypt certificate expiry notifications
ACME_EMAIL=your@email.com

# Legacy single-domain (kept for reference — use N8N_DOMAIN above)
# DOMAIN_NAME=n8n.yourdomain.com


# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Generate a strong password: openssl rand -base64 32
POSTGRES_USER=n8n
POSTGRES_PASSWORD=CHANGE_ME_strong_postgres_password
POSTGRES_DB=n8n


# ── n8n Security ─────────────────────────────────────────────────────────────
# Encryption key for all n8n credentials (NEVER change after first run)
# Generate: openssl rand -hex 32
N8N_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# n8n UI login (protects the workflow editor)
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_strong_ui_password


# ── Kommo CRM OAuth ──────────────────────────────────────────────────────────
KOMMO_CLIENT_ID=207fbba8-d739-4db8-940b-6d9df3f74c1c
KOMMO_CLIENT_SECRET=CHANGE_ME
KOMMO_REDIRECT_URI=http://localhost
KOMMO_SUBDOMAIN=clinicabelba

# Fernet key for encrypting stored OAuth tokens
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=CHANGE_ME_fernet_key

# Paths (relative to /app inside container)
TOKEN_STORE_PATH=/app/auth/token_store.json
SYNC_STATE_PATH=/app/state/sync_state.json


# ── Google APIs ───────────────────────────────────────────────────────────────
# Absolute path inside the container (mounted from /opt/kommo-platform/secrets/)
GOOGLE_SERVICE_ACCOUNT_FILE=/app/secrets/kommo-service-account.json
GOOGLE_SHEETS_SPREADSHEET_ID=16ii02kNP5QpbnHMdjFoi_-cyBlehf85tBHD0x9njsfI
GOOGLE_DRIVE_FOLDER_ID=1QmYTlXorCGiqwG3Vrn3yaCJEbjViS3bt


# ── Slack Alerts ──────────────────────────────────────────────────────────────
KOMMO_SLACK_WEBHOOK=https://hooks.slack.com/services/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


# ── Email Alerts (Gmail) ──────────────────────────────────────────────────────
KOMMO_ALERT_EMAIL_TO=your@email.com


# ── Anthropic (Claude AI) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=CHANGE_ME


# ── Pipeline Tuning ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_TO_FILE=true
OUTPUT_DIR=/app/outputs
LOG_DIR=/app/logs
KOMMO_MAX_PAGE_SIZE=250
KOMMO_RATE_LIMIT_PER_SECOND=7
KOMMO_MAX_RETRIES=3
